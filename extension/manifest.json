{
  "manifest_version": 3,
  "name": "SalusVPN",
  "version": "0.1.0",
  "description": "Verify relay infrastructure, view trust information, and connect Phantom, MetaMask, or Solflare directly.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SalusVPN",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["storage", "tabs", "scripting", "activeTab", "notifications", "sidePanel"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": [
      "icons/logo.svg",
      "icons/icon16.png",
      "icons/icon48.png",
      "icons/icon128.png",
      "session-hud.css"
    ],
    "matches": ["<all_urls>"]
  }]
}
