{
  "manifest_version": 3,
  "name": "SalusVPN Chrome Extension",
  "version": "0.1.0",
  "description": "Verify relay infrastructure, view trust information, and connect a wallet via the SalusVPN dashboard.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SalusVPN"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
