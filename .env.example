# --- SalusVPN AI Trust Advisor ---
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored, so secrets never get committed.

# Google Gemini API key. Create one at https://aistudio.google.com/app/apikey
# NOTE: no NEXT_PUBLIC_ prefix on purpose — this key must stay server-side only.
GEMINI_API_KEY=your-gemini-api-key-here

# (Optional) Override the Gemini model used for recommendations.
# Defaults to "gemini-2.0-flash" if unset. See src/lib/gemini.ts.
GEMINI_MODEL=gemini-2.0-flash
